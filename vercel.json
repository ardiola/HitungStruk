{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*\\.(html|js|css|json|webmanifest|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "headers": { "Cache-Control": "public, max-age=3600" },
      "dest": "/public/$1"
    },
    {
      "src": "/(manifest\\.webmanifest)",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
